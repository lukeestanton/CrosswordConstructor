# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Scraping / external sources ---
# NYT session cookie. Never sent anywhere except NYT endpoints.
# Paste the NYT-S value EXACTLY as the browser shows it — including the leading
# "0^" and trailing "=". Trimming either character breaks authentication
# (the puzzle list still works since it's public, but solve history returns 401).
# Long-lived: NYT-S is valid ~1 year, so you rarely need to refresh it.
TIMES_COOKIE=
# Community poll archive (Reddit solve-rating data).
POLL_ARCHIVE_URL=

# --- Database ---
# SQLite file owned by the Python layer. Omit to use backend/data/crossword.db.
# DATABASE_URL=sqlite:////absolute/path/to/crossword.db

# --- LLM features ---
ANTHROPIC_API_KEY=sk-ant-...
