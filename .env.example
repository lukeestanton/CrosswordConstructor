# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Scraping / external sources ---
# NYT session cookie. Never sent anywhere except NYT endpoints.
TIMES_COOKIE=
# Community poll archive (Reddit solve-rating data).
POLL_ARCHIVE_URL=

# --- Database ---
# SQLite file owned by the Python layer. Omit to use backend/data/crossword.db.
# DATABASE_URL=sqlite:////absolute/path/to/crossword.db

# --- LLM features ---
ANTHROPIC_API_KEY=sk-ant-...
